n = 4
INF = 99999999

graph = [
    [0,   5, INF, 10],
    [INF, 0,   3, INF],
    [INF, INF, 0,   1],
    [INF, INF, INF, 0]
]

for k in range(0, n)
    for i in range(0, n)
        for j in range(0, n)
            if graph[i][j] > graph[i][k] + graph[k][j]
                graph[i][j] = graph[i][k] + graph[k][j]

for i in range(0, n)
    for j in range(0, n)
        if graph[i][j] == INF
            write("INF", end=" ")
        else
            write(graph[i][j], end=" ")
    write()